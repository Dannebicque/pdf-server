WORKDIR_BASE=./var/work
TMP_PDF_DIR=./var/tmp

PDF_SERVER_HOST=127.0.0.1
PDF_SERVER_PORT=8088

PDF_API_TOKEN=change-me-api-token
PDF_API_HMAC_SECRET=change-me-api-hmac-secret

TMP_URL_HMAC_SECRET=change-me-tmpurl-secret
TMP_URL_TTL_SECONDS=900

REDIS_URL=redis://127.0.0.1:6379/0

WORKDIR_BASE=./var/lib/pdf-server/work
TMP_PDF_DIR=./var/lib/pdf-server/tmp

CALLBACK_BEARER=change-me-callback-bearer
CALLBACK_HMAC_SECRET=change-me-callback-hmac-secret

MAX_PAYLOAD_BYTES=15000000
MAX_LATEX_ZIP_BYTES=25000000

PUBLIC_HOST=pdf.example.org
PUBLIC_SCHEME=https